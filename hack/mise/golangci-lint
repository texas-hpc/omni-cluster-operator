#!/usr/bin/env bash
set -euo pipefail

if [[ ! -f .custom-gcl.yml ]]; then
  exec golangci-lint "$@"
fi

mkdir -p bin
binary="bin/golangci-lint"

if [[ ! -x "${binary}" || .custom-gcl.yml -nt "${binary}" ]]; then
  echo "Building custom golangci-lint with module plugins..."
  golangci-lint custom --destination bin --name golangci-lint-custom
  mv -f bin/golangci-lint-custom "${binary}"
fi

exec "${binary}" "$@"
