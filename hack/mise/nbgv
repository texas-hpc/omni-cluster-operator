#!/usr/bin/env bash
set -euo pipefail

version="${NBGV_VERSION:-3.9.50}"
tool_dir="bin/dotnet-tools"
binary="${tool_dir}/nbgv"
stamp="${tool_dir}/.nbgv-${version}"
lock_dir="${tool_dir}.lock"

mkdir -p "$(dirname "${tool_dir}")"

while ! mkdir "${lock_dir}" >/dev/null 2>&1; do
  sleep 1
done
trap 'rmdir "${lock_dir}" >/dev/null 2>&1 || true' EXIT

if [[ ! -x "${binary}" || ! -f "${stamp}" ]]; then
 rm -rf "${tool_dir}"
  mkdir -p "${tool_dir}"
  dotnet tool install --tool-path "${tool_dir}" nbgv --version "${version}" >/dev/null
  touch "${stamp}"
fi

trap - EXIT
rmdir "${lock_dir}" >/dev/null 2>&1 || true

exec "${binary}" "$@"
