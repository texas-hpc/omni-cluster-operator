#!/usr/bin/env bash
set -euo pipefail

namespace="${OMNI_NAMESPACE:-omni-system}"
output="${OMNI_LIVE_SERVICE_ACCOUNT_KEY_FILE:-.local/omni/service-account.key}"
timeout_seconds="${OMNI_INITIAL_SERVICE_ACCOUNT_TIMEOUT_SECONDS:-300}"
deadline=$((SECONDS + timeout_seconds))

mkdir -p "$(dirname "${output}")"

while (( SECONDS < deadline )); do
  pod="$(kubectl get pods -n "${namespace}" -l app.kubernetes.io/name=omni \
    -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)"
  if [[ -n "${pod}" ]]; then
    if kubectl exec -n "${namespace}" "${pod}" -- test -s /data/initial-service-account-key >/dev/null 2>&1; then
      kubectl exec -n "${namespace}" "${pod}" -- cat /data/initial-service-account-key > "${output}"
      chmod 0600 "${output}"
      echo "${output}"
      exit 0
    fi
  fi
  sleep 5
done

echo "timed out waiting for Omni initial service account key" >&2
exit 1
