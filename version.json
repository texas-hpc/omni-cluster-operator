{
  "$schema": "https://raw.githubusercontent.com/dotnet/Nerdbank.GitVersioning/main/src/NerdBank.GitVersioning/version.schema.json",
  "version": "1.0",
  "versionHeightOffset": -1,
  "versionHeightOffsetAppliesTo": "1.0",
  "pathFilters": [
    ":/.dockerignore",
    ":/Dockerfile",
    ":/api",
    ":/charts",
    ":/cmd",
    ":/config",
    ":/go.mod",
    ":/go.sum",
    ":/internal",
    ":/mise-tasks/build",
    ":/mise-tasks/build-installer",
    ":/mise-tasks/chart-package",
    ":/mise-tasks/chart-sync-crds",
    ":/mise-tasks/chart-template",
    ":/mise-tasks/docker-build",
    ":/mise-tasks/docker-buildx",
    ":/mise-tasks/docker-push",
    ":/mise-tasks/generate",
    ":/mise-tasks/manifests",
    ":/mise-tasks/render-default",
    ":/mise-tasks/samples",
    ":/mise.toml",
    ":/version.json"
  ],
  "publicReleaseRefSpec": [
    "^refs/heads/master$"
  ],
  "cloudBuild": {
    "buildNumber": {
      "enabled": true
    },
    "setVersionVariables": true,
    "setAllVariables": true
  }
}
