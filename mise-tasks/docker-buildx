#!/usr/bin/env bash
#MISE description="Build and push a multi-arch manager image with docker buildx."
set -euo pipefail

container_tool="${CONTAINER_TOOL:-docker}"
builder_name="omni-cluster-operator-builder"
platforms="${PLATFORMS:-linux/arm64,linux/amd64,linux/s390x,linux/ppc64le}"
image="${IMG:-${OMNI_OPERATOR_IMG:-omni-cluster-operator:dev}}"
tmp_dockerfile="$(mktemp Dockerfile.cross.XXXXXX)"
trap 'rm -f "${tmp_dockerfile}"; "${container_tool}" buildx rm "${builder_name}" >/dev/null 2>&1 || true' EXIT

awk '
  /^FROM / && !done {
    sub(/^FROM /, "FROM --platform=${BUILDPLATFORM} ")
    done = 1
  }
  { print }
' Dockerfile > "${tmp_dockerfile}"
"${container_tool}" buildx create --name "${builder_name}" >/dev/null 2>&1 || true
"${container_tool}" buildx use "${builder_name}"
"${container_tool}" buildx build --push --platform="${platforms}" --tag "${image}" -f "${tmp_dockerfile}" .
