#!/usr/bin/env bash
#MISE description="Generate a consolidated install manifest in dist/install.yaml."
set -euo pipefail

image="${IMG:-${OMNI_OPERATOR_IMG:-omni-cluster-operator:dev}}"

mise run manifests
mise run generate

mkdir -p dist
hack/mise/kustomize-build-with-image config/default "${image}" > dist/install.yaml
