#!/usr/bin/env bash
#MISE description="Run opt-in live tests against a real Omni endpoint."
set -euo pipefail

key_file="${OMNI_LIVE_SERVICE_ACCOUNT_KEY_FILE:-.local/omni/service-account.key}"
if [[ ! -s "${key_file}" ]]; then
  echo "missing Omni service account key: ${key_file}" >&2
  echo "run 'mise run omni-up' first, or set OMNI_E2E_SERVICE_ACCOUNT_KEY_FILE" >&2
  exit 1
fi

OMNI_E2E_ENDPOINT="${OMNI_E2E_ENDPOINT:-${OMNI_LIVE_ENDPOINT:-http://omni.omni-system.svc.cluster.local:8080}}" \
OMNI_E2E_SERVICE_ACCOUNT_KEY_FILE="${OMNI_E2E_SERVICE_ACCOUNT_KEY_FILE:-${key_file}}" \
LIVE_OMNI_OPERATOR_NAMESPACE="${LIVE_OMNI_OPERATOR_NAMESPACE:-omni-cluster-operator-system}" \
go test -tags=live_omni ./test/live -v
