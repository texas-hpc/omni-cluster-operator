#!/usr/bin/env bash
#MISE description="Run generated-code, vet, and envtest-backed tests."
set -euo pipefail

mise run manifests
mise run generate
mise run fmt
mise run vet
mise run setup-envtest

packages="$(go list ./... | grep -v '/test/e2e$')"
assets="$(setup-envtest use "${ENVTEST_K8S_VERSION:-1.35}" --bin-dir bin -p path)"
KUBEBUILDER_ASSETS="${assets}" go test ${packages} -coverprofile cover.out
