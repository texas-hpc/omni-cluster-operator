{
  "name": "Omni Cluster Operator",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false,
      "dockerDefaultAddressPool": "base=172.30.0.0/16,size=24"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "upgradePackages": true
    }
  },

  "runArgs": ["--privileged", "--init"],

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "mise.binPath": "/usr/local/bin/mise",
        "mise.configureExtensionsAutomatically": true,
        "mise.configureExtensionsAutomaticallyIncludeList": ["golang.go"],
        "mise.configureExtensionsIncludeGlobalTools": false,
        "mise.configureExtensionsUseShims": true,
        "mise.updateEnvAutomatically": true,
        "mise.updateOpenTerminalsEnvAutomatically": true
      },
      "extensions": [
        "hverlin.mise-vscode",
        "golang.go",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-docker"
      ]
    }
  },

  "remoteEnv": {
    "GO111MODULE": "on",
    "PATH": "/usr/local/share/mise/shims:/usr/local/bin:${containerEnv:PATH}"
  },

  "postCreateCommand": "mise trust && mise install && mise run setup-envtest"
}
